# Relative paths: correct for `uvicorn` run from the server/ directory.
# Docker Compose overrides these to /data/...; the host mount is ../save_data (repo root).
SAVE_ROOT=./data/saves
HISTORY_ROOT=./data/history
INDEX_PATH=./data/index.json
API_KEY=change-me
ENABLE_VERSION_HISTORY=true

# When true, logs client wall clock uploads (query client_clock_utc) and POST /debug/client-clock bodies.
# Set Docker/uvicorn log level to info to see lines (e.g. LOG_LEVEL=info).
SAVE_SYNC_LOG_CLIENT_DEBUG=false
